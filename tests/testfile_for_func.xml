<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns">
	<data key="gFormat">Cyberiada-GraphML-1.0</data>

	<key attr.name="name" attr.type="string" for="node" id="dName"></key>
	<key attr.name="data" attr.type="string" for="node" id="dData"></key>
	<key attr.name="data" attr.type="string" for="edge" id="dData"></key>
	<key for="node" id="dVertex"></key>
	<key for="node" id="dGeometry"></key>
	<key for="edge" id="dGeometry"></key>

	<graph id="func_sum" edgedefault="directed">
		<data key="dName">Функция сложения</data>
		<data key="dStateMachine">true</data>

		<node id="input_a">
			<data key="dVertex">input</data>
			<data key="dName">a</data>
			<data key="dData">int</data>
			<data key="dGeometry">
				<rect x="50" y="100" width="40" height="40"></rect>
			</data>
		</node>

		<node id="input_b">
			<data key="dVertex">input</data>
			<data key="dName">b</data>
			<data key="dData">int</data>
			<data key="dGeometry">
				<rect x="50" y="200" width="40" height="40"></rect>
			</data>
		</node>

		<node id="output_result">
			<data key="dVertex">output</data>
			<data key="dName">result</data>
			<data key="dData">int</data>
			<data key="dGeometry">
				<rect x="450" y="150" width="40" height="40"></rect>
			</data>
		</node>

		<node id="action_sum">
			<data key="dVertex">block</data>
			<data key="dName">Сложение</data>
			<data key="dData">ADD</data>
			<data key="dGeometry">
				<rect x="200" y="150" width="150" height="50"></rect>
			</data>
		</node>

		<edge id="e1" source="input_a" target="action_sum">
			<data key="dData">a</data>
		</edge>
		<edge id="e2" source="input_b" target="action_sum">
			<data key="dData">b</data>
		</edge>
		<edge id="e3" source="action_sum" target="output_result">
			<data key="dData">result</data>
		</edge>
	</graph>
</graphml>